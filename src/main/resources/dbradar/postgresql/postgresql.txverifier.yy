create_table:
    CREATE TABLE _new_table_name (first_new_column more_new_column*)

first_new_column:
    new_column

more_new_column:
    , new_column

new_column:
    _new_column_name type_name column_constraint? column_constraint?

type_name:
    INT
    | BOOLEAN
    | TEXT
    | DECIMAL
    | FLOAT
    | REAL

column_constraint:
    default_expr?
    | generated_constraint          @disable-query{c\d+\s}

default_expr:
    DEFAULT (numerical_expr)

generated_constraint:
    GENERATED ALWAYS AS (numerical_expr) STORED
    | GENERATED ALWAYS AS IDENTITY
    | GENERATED BY DEFAULT AS IDENTITY


expr:
    _column
    @disable-symbol alter_table
    | bool_expr
    | numerical_expr
    | bit_expr
    | varchar_expr
    | column_expr

exprs:
    , expr

column_expr:
 #   _column binary_arithmetic_op _column
    arithmetic_prefix _column
#    | _column binary_logical_op _column

bool_expr:
    ((bool_expr) NOT? IN (bool_expr))
    | ((numerical_expr) NOT? IN (numerical_expr))
    | ((bit_expr) NOT? IN (bit_expr))
    | ((varchar_expr) NOT? IN (varchar_expr))
    | ((numerical_expr) NOT? BETWEEN (numerical_expr) AND (numerical_expr))
    | (bool_expr) binary_logical_op (bool_expr)
    | TRUE
    | FALSE
    | NOT(bool_expr)
    | ((expr) IS NULL)
    | ((expr) IS NOT NULL)
    | (numerical_expr) binary_comparison_op (numerical_expr)
    | (varchar_expr) NOT? LIKE (varchar_expr)

binary_logical_op:
    AND
    | OR
    | !=

binary_comparison_op:
    <
    | <=
    | >
    | {print("=")}

numerical_expr:
    int_expr
    | float_expr
    | double_expr
    | _digit
    | (numerical_expr) binary_arithmetic_op (numerical_expr)
    | (arithmetic_prefix(numerical_expr))
    # | numerical_funcs

numerical_exprs:
    , numerical_expr

int_expr:
    _int8
    | _int8_unsigned

binary_arithmetic_op:
    {print("+")}
    | {print("-")}
    | {print("*")}
    | {print("/")}
    | {print("%")}

float_expr:
    _float
    | _float_unsigned

double_expr:
    _double
    | _double_unsigned

arithmetic_prefix:
    {print("+")}
    | {print("-")}

numerical_bitwise_expr:
    (numerical_expr) binary_bitwise_op (numerical_expr)
    | {print("~")} (numerical_expr)

binary_bitwise_op:
    {print("|")}
    | {print("&")}
    | {print("<<")}
    | {print(">>")}

bit_expr:
    bit_string
    | {print("~")} (bit_string)

bit_string:
    {print("'")}bit_value+{print("' :: BIT")}

bit_strings:
    , bit_string

bit_value:
    1
    | 0

bitstring:
    b'00101'
    | b'00001'
    | b'0'
    | b'1'

numerical_funcs:
    abs(numerical_expr)
    | bit_length(bit_string)
    | bit_count(bit_string)
    | get_bit(bit_string,0)
    | length(bit_string)
    | octet_length(bit_string)
    | acos(numerical_expr)
    | asin(numerical_expr)
    | atan(numerical_expr)
    | atan2(numerical_expr, numerical_expr)
    | cbrt(numerical_expr)
    | ceil(numerical_expr)
    | ceiling(numerical_expr)
    | cos(numerical_expr)
    | cot(numerical_expr)
    | degrees(numerical_expr)
    | even(numerical_expr)
    | exp(numerical_expr)
    | floor(numerical_expr)
    | gamma(numerical_expr)
    | gcd(numerical_expr, numerical_expr)
    | greatest(numerical_expr numerical_exprs*)
    | isnan(numerical_expr)
    | lcm(numerical_expr, numerical_expr)
    | least(numerical_expr numerical_exprs*)
    | ln(numerical_expr)
    | log(numerical_expr)
    | log2(numerical_expr)
    | log10(numerical_expr)
    | nextafter(numerical_expr, numerical_expr)
    | pi()
    | pow(numerical_expr, numerical_expr)
    | power(numerical_expr, numerical_expr)
    | radians(numerical_expr)
    | random()    @disable-oracle equation
    | round(numerical_expr, int_expr)
    | setseed(numerical_expr)
    | sin(numerical_expr)
    | sign(numerical_expr)
    | signbit(numerical_expr)
    | sqrt(numerical_expr)
    | xor(numerical_expr)
    | tan(numerical_expr)
    | @(numerical_expr)

varchar_expr:
    _text
    | _char


order_option:
    ASC
    @disable-query{USING HASH.*ASC}         # access method "hash" does not support ASC/DESC options
    | DESC
    @disable-query{USING HASH.*DESC}        # access method "hash" does not support ASC/DESC options
    | NULLS FIRST
    @disable-query{USING HASH.*NULLS FIRST} # access method "hash" does not support NULLS FIRST/LAST options
    | NULLS LAST
    @disable-query{USING HASH.*NULLS LAST}  # access method "hash" does not support NULLS FIRST/LAST options

where_clause:
    WHERE bool_expr


# INSERT
insert:
    INSERT INTO _table (_insert_columns) VALUES (_insert_values)


# UPDATE
update:
    UPDATE _table SET assignment assignment_more* where_clause?
    | UPDATE _table SET assignment assignment_more* where_clause
    | UPDATE _table SET assignment assignment_more* where_clause

assignment:
    _distinct_column = _value

assignment_more:
   , assignment


# DELETE
delete:
    DELETE FROM _table where_clause?
    | DELETE FROM _table where_clause
    | DELETE FROM _table where_clause


# SELECT
select:
    SELECT all_or_distinct? field_list FROM _table where_clause?
    | SELECT field_list FROM _table where_clause?
    | SELECT field_list FROM _table where_clause?
    | SELECT field_list FROM _table
    | SELECT field_list FROM _table where_clause
    | SELECT field_list FROM _table where_clause

all_or_distinct:
    ALL
    | DISTINCT

field_list:
    _column AS _column_alias,
    _column AS _column_alias,
    _column AS _column_alias


# BEGIN TRANSACTION
begin:
    BEGIN
    | START TRANSACTION

# ROLLBACK
rollback:
    ROLLBACK

# COMMIT
commit:
    COMMIT
